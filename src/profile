# Set the font for 9term and acme.
font=/mnt/font/InputSans-Regular/14a/font

# `nobs` strips control-characters from text stream.
# (e.g. `git diff` doesn't paginate)
PAGER=nobs

# My binaries
PATH=$PATH:$home/.bin

# brew
HOMEBREW_PREFIX="/opt/homebrew"
HOMEBREW_CELLAR="/opt/homebrew/Cellar"
HOMEBREW_REPOSITORY="/opt/homebrew"
PATH=$PATH:/opt/homebrew/bin

# go
PATH=$PATH:$home/go/bin
