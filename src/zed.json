{
  // sublime-ish
  "theme": "One Dark",
  "base_keymap": "SublimeText",

  // typography
  "buffer_line_height": "standard",
  "buffer_font_family": "Berkeley Mono Variable",
  "ui_font_family": "Berkeley Mono Variable",

  // hide stuff
  "disable_ai": true,
  "cursor_blink": false,
  "inline_code_actions": false,
  "wrap_guides": [88],
  "title_bar": {
    "show_project_items": false,
    "show_sign_in": false,
    "show_user_menu": false,
    "show_branch_name": false
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false
  },
  "gutter": {
    "breakpoints": false,
    "bookmarks": false,
    "folds": false,
    "min_line_number_digits": 3,
    "runnables": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false
  },
  "project_panel": {
    "button": false
  },
  "terminal": {
    "button": false,
    "font_family": "Berkeley Mono Variable"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "indent_guides": {
    "enabled": false
  },
  "scrollbar": {
    "diagnostics": "none"
  },
  "diagnostics": {
    "button": false
  },
  "search": {
    "button": false
  },
  "debugger": {
    "button": false
  },
  "outline_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "git_panel": {
    "button": false
  },
  "global_lsp_settings": {
    "button": false
  }
}
