#!/bin/zsh
set -e

# home directory
ln -sf $(pwd)/zshrc          ~/.zshrc
ln -sf $(pwd)/aerospace.toml ~/.aerospace.toml

# bin directory
chmod +x ~/.bin
go build -o align align.go && mv align ~/.bin
ln -sf $(pwd)/pass ~/.bin/pass

# config directory
mkdir -p ~/.config
[ ! -e ~/.config/ghostty ] && ln -sf $(pwd)/ghostty ~/.config/ghostty
